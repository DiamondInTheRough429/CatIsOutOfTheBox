[sub_resource type="GDScript" id="GDScript_rrefv"]
resource_name = "Customize"
script/source = "extends VBoxContainer

@export var Buttons:Array[CosmeticButton]

func _ready() -> void:
	for Butt in Buttons:
		Butt.pressed.connect(UpdateAll)

func UpdateAll() -> void:
	for Butt in Buttons:
		Butt.UpdateLook.call_deferred()
"

