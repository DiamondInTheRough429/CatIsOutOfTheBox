[sub_resource type="GDScript" id="GDScript_geipl"]
resource_name = "TestMenu"
script/source = "extends Control

@export var ContinueButton:Button
@export var Worlds:Array[MadeLevelPack]
var ContinueWorld:int = 0
var ContinueLevel:int  = 1

func _ready() -> void:
	ContinueButton.pressed.connect(ContinueGame)
	var HighComplete:Vector2i = SaveHandler.HelpContinue()
	ContinueWorld = HighComplete.x
	ContinueLevel = HighComplete.y+1
	ContinueButton.text = tr(\"CONTINUE\").format({\"WORLD\" : \"%03d\" %ContinueWorld, \"LEVEL\" : \"%03d\" %ContinueLevel})

func ContinueGame()->void:
	var ContinueInfo:LevelInfo = Worlds.get(ContinueWorld).Levels.get(ContinueLevel-1)
	get_tree().change_scene_to_file.call_deferred(ContinueInfo.LevelUID)
"

