[sub_resource type="GDScript" id="GDScript_geipl"]
resource_name = "TestMenu"
script/source = "extends Control

@export var LoadButton:Button
@export var LoadSceneUID:String

func _ready() -> void:
	LoadButton.pressed.connect(Fo)

func Fo()->void:
	get_tree().change_scene_to_file.call_deferred(LoadSceneUID)
"

