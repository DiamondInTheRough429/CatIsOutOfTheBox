[sub_resource type="GDScript" id="GDScript_kgf1m"]
resource_name = "Credits"
script/source = "extends MenuHandler
class_name Creditmenu

@export var DTwitch:Button

func _ready() -> void:
	super._ready()
	#DTwitch.pressed.connect(DTwitchPress) # this was causing the game to crash :(

func DTwitchPress() -> void:
	OS.shell_open(\"https://www.twitch.tv/diamondintherough429\")
"

[node name="Credits" type="PanelContainer" node_paths=PackedStringArray("FirstFocus", "GoBackButton")]
custom_minimum_size = Vector2(600, 300)
theme = ExtResource("1_kwoi3")
script = SubResource("GDScript_kgf1m")
FirstFocus = NodePath("VBoxContainer/Button")
