; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CatIsOutOfTheBox-DIJ"
config/description="Get The Cat Out Of The Box"
run/main_scene="uid://buvo6k3q5bmq1"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SaveHandler="*res://GameHandler/SaveFile/SaveHandler.gd"
SettingsHandler="*res://GameHandler/Settings/SettingsHandler.gd"
GlobalMusicHandler="*res://GameHandler/GlobalMusic/GlobalMusic.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=320
window/size/window_width_override=1920
window/size/window_height_override=960
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"
window/vsync/vsync_mode=0

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/fancy_folder_colors/plugin.cfg", "res://addons/fancy_folder_icons/plugin.cfg")

