[sub_resource type="GDScript" id="GDScript_p7apf"]
resource_name = "OverideTile"
script/source = "extends Node

@export var Level:LevelHandler
@export var TileSpot:Vector2i
var TiletoOveride:Observable

func _ready() -> void:
	Level.LevelReady.connect(LevelReady)

func LevelReady() -> void:
	TiletoOveride = Level.PositionToTiles.get(TileSpot)
	if TiletoOveride != null:
		TiletoOveride.Observed = TileHanlder.WhenObserved.Was
		TiletoOveride.set_meta(\"DefaultObserved\", TileHanlder.WhenObserved.Was)
"

